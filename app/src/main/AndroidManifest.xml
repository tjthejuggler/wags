<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- BLE permissions for API 31+ -->
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <!-- Location for BLE scanning on API < 31 -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.BLUETOOTH" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- Vibration -->
    <uses-permission android:name="android.permission.VIBRATE" />
    <!-- Internet for YouTube oEmbed metadata fetch -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!--
        Tail app IPC: signature permission declared by the Tail app.
        Required both to query the ContentProvider (readPermission) and to
        send the increment broadcast (receiverPermission).
    -->
    <uses-permission android:name="com.example.tail.permission.TAIL_INTEGRATION" />

    <uses-feature android:name="android.hardware.bluetooth_le" android:required="false" />

    <!-- Android 11+ package visibility: allow querying the Tail app -->
    <queries>
        <package android:name="com.example.tail" />
        <provider android:authorities="com.example.tail.provider" />
        <!-- Garmin Connect Mobile app — required for Connect IQ SDK communication -->
        <package android:name="com.garmin.android.apps.connectmobile" />
        <!-- Spotify — required for isSpotifyInstalled() check and media button routing -->
        <package android:name="com.spotify.music" />
    </queries>

    <application
        android:name=".WagsApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Wags">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:label="@string/app_name"
            android:theme="@style/Theme.Wags">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Spotify OAuth PKCE redirect -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />

                <data
                    android:scheme="wags"
                    android:host="spotify-callback" />
            </intent-filter>
        </activity>

        <service
            android:name=".data.ble.BleService"
            android:foregroundServiceType="connectedDevice"
            android:exported="false" />

        <!--
            NotificationListenerService required for MediaSession access.
            Used by SpotifyManager to detect currently-playing track metadata
            and send play commands to Spotify.
        -->
        <service
            android:name=".data.spotify.MediaNotificationListener"
            android:exported="true"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>
    </application>

</manifest>
